includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - vendor
    ignoreErrors:
        # Generic array value types in docblocks are not enforced across the
        # (largely inherited) console layer; not a correctness concern.
        -
            identifier: missingType.iterableValue
        # ConsoleProgressBar is a stateful wrapper: $progressBar is null until
        # startProgressBar() is called and $consoleOutput is set in the ctor;
        # its call contract assumes start-before-use.
        -
            identifier: method.nonObject
            path: src/Formatting/ConsoleProgressBar.php
        -
            identifier: argument.type
            path: src/Formatting/ConsoleProgressBar.php
        -
            identifier: return.phpDocType
            path: src/Formatting/ConsoleProgressBar.php
        # Terminal capability detection legitimately reads process env vars
        # (NO_COLOR/TERM); these are not Laravel config keys.
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: src/Formatting/ConsoleUIFormatter.php
        # Performance metrics index by a computed numeric key; harmless.
        -
            identifier: offsetAccess.invalidOffset
            path: src/Commands/Services/CommandPerformanceService.php
        # Command observer matches against names that may arrive as mixed.
        -
            identifier: argument.type
            path: src/Observers/ConsoleCommandObserver.php
    treatPhpDocTypesAsCertain: false
