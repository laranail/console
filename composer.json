{
  "name": "laranail/console",
  "description": "A Rich-class console toolkit for Laravel — fluent output formatter, spinners, progress bars, boxes, trees and tables, plus a fluent prompts/forms layer with validators.",
  "keywords": [
    "laravel",
    "console",
    "artisan",
    "terminal",
    "tui",
    "formatter",
    "spinner",
    "progress",
    "prompts",
    "forms",
    "laranail"
  ],
  "homepage": "https://opensource.simtabi.com/console/",
  "license": "MIT",
  "authors": [
    {
      "name": "Simtabi LLC",
      "email": "opensource@simtabi.com",
      "homepage": "https://opensource.simtabi.com",
      "role": "Organization"
    },
    {
      "name": "Imani Manyara",
      "email": "imani@simtabi.com",
      "role": "Maintainer"
    }
  ],
  "support": {
    "issues": "https://github.com/laranail/console/issues",
    "source": "https://github.com/laranail/console",
    "docs": "https://opensource.simtabi.com/console/docs/"
  },
  "require": {
    "php": "^8.4.1",
    "ext-mbstring": "*",
    "illuminate/console": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/support": "^13.0",
    "laravel/prompts": "^0.3.18|^1.0",
    "symfony/console": "^8.0"
  },
  "require-dev": {
    "infection/infection": "^0.33",
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.18",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "phpbench/phpbench": "^1.4",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.0",
    "rector/rector": "^2.0",
    "roave/security-advisories": "dev-latest",
    "symfony/tui": "^8.2@dev"
  },
  "suggest": {
    "symfony/tui": "(experimental, PHP >= 8.4.1) Enables the full-screen TUI integration — Console::tui() + Console\\Tui\\RenderableWidget."
  },
  "autoload": {
    "psr-4": {
      "Simtabi\\Laranail\\Console\\": "src/Console/"
    },
    "files": [
      "helpers/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Simtabi\\Laranail\\Console\\Tools\\Tests\\": "tests/Tools/",
      "Simtabi\\Laranail\\Console\\Prompter\\Tests\\": "tests/Prompter/",
      "Simtabi\\Laranail\\Console\\Benchmarks\\": "benchmarks/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest --no-coverage --colors=always",
    "bench": "vendor/bin/phpbench run --report=aggregate",
    "test-coverage": "vendor/bin/pest --coverage --colors=always",
    "test-dirty": "@test --dirty --compact",
    "examples": [
      "php examples/tools/widgets.php > /dev/null",
      "php examples/tools/design_system.php > /dev/null",
      "php examples/tools/colors.php > /dev/null",
      "php examples/tools/typography.php > /dev/null",
      "php examples/tools/markdown.php > /dev/null",
      "php examples/tools/theming.php > /dev/null",
      "php examples/tools/barchart.php > /dev/null",
      "php examples/tools/charts.php > /dev/null",
      "php examples/tools/emoji.php > /dev/null",
      "php examples/tools/symbols.php > /dev/null",
      "php examples/tools/writing.php > /dev/null 2>&1",
      "php examples/tools/interactive.php > /dev/null",
      "php examples/tools/menu.php > /dev/null",
      "php examples/tools/tui.php > /dev/null",
      "php examples/prompter/validators.php > /dev/null"
    ],
    "lint": [
      "@pint",
      "@phpstan",
      "@rector"
    ],
    "pint": "vendor/bin/pint --test",
    "pint-fix": "vendor/bin/pint",
    "phpstan": "vendor/bin/phpstan analyse --no-progress",
    "rector": "vendor/bin/rector process --dry-run",
    "rector-fix": "vendor/bin/rector process",
    "audit": [
      "@composer-audit"
    ],
    "composer-audit": "@composer audit"
  },
  "replace": {
    "laranail/console-tools": "*",
    "laranail/prompter": "*"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "2.x-dev"
    },
    "laravel": {
      "providers": [
        "Simtabi\\Laranail\\Console\\Providers\\ConsoleServiceProvider"
      ],
      "aliases": {
        "Console": "Simtabi\\Laranail\\Console\\Facades\\Console",
        "Prompter": "Simtabi\\Laranail\\Console\\Prompter\\Facades\\PrompterFacade"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true,
      "pestphp/pest-plugin": true
    },
    "audit": {
      "abandoned": "report"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
