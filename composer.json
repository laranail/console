{
  "name": "laranail/console-tools",
  "description": "Console & terminal-UI toolkit for Laravel packages — fluent output formatter, progress bars, and an enhanced Artisan command base with service-based architecture.",
  "keywords": [
    "laravel",
    "console",
    "artisan",
    "terminal",
    "formatter",
    "laranail",
    "console-tools"
  ],
  "homepage": "https://opensource.simtabi.com/console-tools/",
  "license": "MIT",
  "authors": [
    {
      "name": "Simtabi LLC",
      "email": "opensource@simtabi.com",
      "homepage": "https://opensource.simtabi.com",
      "role": "Organization"
    },
    {
      "name": "Imani Manyara",
      "email": "imani@simtabi.com",
      "role": "Maintainer"
    }
  ],
  "support": {
    "issues": "https://github.com/laranail/console-tools/issues",
    "source": "https://github.com/laranail/console-tools",
    "docs": "https://opensource.simtabi.com/console-tools/docs/"
  },
  "require": {
    "php": "^8.3 || ^8.4 || ^8.5",
    "illuminate/console": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/support": "^13.0",
    "laravel/prompts": "^0.3|^1.0",
    "symfony/console": "^7.0|^8.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^3.0",
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.18",
    "rector/rector": "^2.0",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Simtabi\\Laranail\\ConsoleTools\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Simtabi\\Laranail\\ConsoleTools\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": "bash .scripts/init.sh",
    "test": "vendor/bin/pest --colors=always",
    "test-coverage": "@test --coverage",
    "test-dirty": "@test --dirty --compact",
    "lint": [
      "@pint",
      "@phpstan",
      "@rector"
    ],
    "pint": "vendor/bin/pint --test",
    "pint-fix": "vendor/bin/pint",
    "phpstan": "vendor/bin/phpstan analyse --no-progress",
    "rector": "vendor/bin/rector process --dry-run",
    "rector-fix": "vendor/bin/rector process",
    "audit": [
      "@composer-audit"
    ],
    "composer-audit": "@composer audit"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    },
    "laravel": {
      "providers": [
        "Simtabi\\Laranail\\ConsoleTools\\Providers\\ConsoleToolsServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
